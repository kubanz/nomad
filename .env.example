# Vercel Blob — токен для загрузки фото туров
# Получить: https://vercel.com/dashboard → Storage → nomad-blob → Settings
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxx

# Секрет авторизации админ-панели (минимум 16 символов, лучше 32+ случайных).
# Сгенерировать: node -e "console.log(crypto.randomBytes(32).toString('hex'))"
# Им подписываются куки сессий и шифруются данные админки в Vercel Blob.
# При смене секрета все сессии «слетят», а данные админки в Blob станут нечитаемыми!
ADMIN_AUTH_SECRET=

# Хранилище данных админки: fs (файлы в .data/admin) или blob (Vercel Blob).
# По умолчанию: в деве — fs, в продакшене — blob (если есть BLOB_READ_WRITE_TOKEN).
# ADMIN_STORE=fs
